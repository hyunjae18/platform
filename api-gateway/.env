# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME=API Gateway
DEBUG=False

# ── JWT — must be IDENTICAL to your Node.js JWT_SECRET ────────────────────────
JWT_SECRET=docmind-secure-jwt-key-2024
ALGORITHM=HS256

# ── Node.js Auth Server ────────────────────────────────────────────────────────
NODE_AUTH_URL=http://localhost:3001

# ── Microservices URLs ─────────────────────────────────────────────────────────
OCR_SERVICE_URL=http://localhost:8000
SEARCH_SERVICE_URL=http://localhost:8003
CLASSIFICATION_SERVICE_URL=http://localhost:8002
METADATA_SERVICE_URL=http://localhost:8004
ARCHIVING_SERVICE_URL=http://localhost:3007
DOCUMENT_SERVICE_URL=http://localhost:3000


# ── Microservices API Keys (leave empty if not used) ──────────────────────────
OCR_API_KEY=
SEARCH_API_KEY=
CLASSIFICATION_API_KEY=
METADATA_API_KEY=
ARCHIVING_API_KEY=