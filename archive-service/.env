# Hot MinIO (port 9010)
MINIO_HOT_ENDPOINT=docmind-archive.duckdns.org
MINIO_HOT_PORT=9010
MINIO_HOT_USE_SSL=false
MINIO_HOT_ACCESS_KEY=minio-archive-admin
MINIO_HOT_SECRET_KEY=MiN10-4RchIV3-S3CreT!2003
MINIO_HOT_BUCKET=docmind-archive
HOT_BUCKET_CAPACITY_BYTES=10737418240
HOT_BUCKET_FILL_PCT=85
# Cold MinIO / NAS archive bucket (port 9010)
MINIO_COLD_ENDPOINT=docmind-archive.duckdns.org
MINIO_COLD_PORT=9010
MINIO_COLD_USE_SSL=false
MINIO_COLD_ACCESS_KEY=minio-archive-admin
MINIO_COLD_SECRET_KEY=MiN10-4RchIV3-S3CreT!2003
MINIO_COLD_BUCKET=docmind-archive

ARCHIVE_STORAGE_DRIVER=mc
MC_ALIAS=docmind
MC_ENDPOINT=http://docmind-archive.duckdns.org:9010
MC_ACCESS_KEY=minio-archive-admin
MC_SECRET_KEY=MiN10-4RchIV3-S3CreT!2003

# Archive policy
ARCHIVE_AFTER_DAYS=30

JWT_SECRET=docmind-secure-jwt-key-2024
JWT_EXPIRES_IN=1h

SERVICE_SHARED_SECRET=your-shared-secret-for-service-communication-change-me

# MongoDB
MONGODB_URI=mongodb://localhost:27017/archive_db

# RabbitMQ
RABBITMQ_URL=amqp://admin:admin123@localhost:5672
GATEWAY_URL=http://localhost:8001

PORT=3007
